{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kaya-dashboard",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "main": "worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "REVIEWS",
      "id": "f118ce880bcf4a08b607debdb4645e17"
    }
  ]
}
